          "strategy": {
            "type": "string",
            "title": "Strategy"
          },
          "total_tasks": {
            "type": "integer",
            "title": "Total Tasks"
          },
          "results": {
            "items": {
              "$ref": "#/components/schemas/RunResult"
            },
            "type": "array",
            "title": "Results"
          },
          "metrics": {
            "additionalProperties": true,
            "type": "object",
            "title": "Metrics"
          }
        },
        "type": "object",
        "required": [
          "strategy",
          "total_tasks",
          "results",
          "metrics"
        ],
        "title": "BatchResult",
        "description": "Result of running a batch of tasks."
      },
      "DatasetStats": {
        "properties": {
          "total_tasks": {
            "type": "integer",
