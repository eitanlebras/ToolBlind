      "TaskSummary": {
        "properties": {
          "task_id": {
            "type": "string",
            "title": "Task Id"
          },
          "tier": {
            "type": "integer",
            "title": "Tier"
          },
          "domain": {
            "type": "string",
            "title": "Domain"
          },
          "goal": {
            "type": "string",
            "title": "Goal"
          },
          "ground_truth_outcome": {
            "type": "string",
            "title": "Ground Truth Outcome"
          },
          "commitment_depth": {
            "type": "integer",
            "title": "Commitment Depth"
          },
          "difficulty": {
            "type": "string",
            "title": "Difficulty"
